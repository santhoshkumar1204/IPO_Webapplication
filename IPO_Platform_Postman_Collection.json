{
  "info": {
    "name": "IPO Platform API",
    "description": "Complete API collection for IPO Platform Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"testuser\",\n    \"email\": \"test@example.com\",\n    \"password\": \"securepass123\",\n    \"first_name\": \"Test\",\n    \"last_name\": \"User\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"User created successfully\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.eql(\"User created successfully\");",
                  "    pm.expect(jsonData.user).to.have.property('username');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (Get JWT Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has tokens\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.access).to.be.a('string');",
                  "    pm.expect(jsonData.refresh).to.be.a('string');",
                  "    pm.collectionVariables.set(\"access_token\", jsonData.access);",
                  "    pm.collectionVariables.set(\"refresh_token\", jsonData.refresh);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh/",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "refresh", ""]
            }
          }
        },
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/profile/",
              "host": ["{{base_url}}"],
              "path": ["api", "profile", ""]
            }
          }
        }
      ]
    },
    {
      "name": "IPO Management",
      "item": [
        {
          "name": "Get All IPOs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/ipos/",
              "host": ["{{base_url}}"],
              "path": ["api", "ipos", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has results array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.results).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"IPO has required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.results.length > 0) {",
                  "        var ipo = jsonData.results[0];",
                  "        pm.expect(ipo).to.have.property('company_name');",
                  "        pm.expect(ipo).to.have.property('price_band');",
                  "        pm.expect(ipo).to.have.property('status');",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Upcoming IPOs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/ipos/upcoming/",
              "host": ["{{base_url}}"],
              "path": ["api", "ipos", "upcoming", ""]
            }
          }
        },
        {
          "name": "Get Open IPOs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/ipos/open_now/",
              "host": ["{{base_url}}"],
              "path": ["api", "ipos", "open_now", ""]
            }
          }
        },
        {
          "name": "Get IPO Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/ipos/statistics/",
              "host": ["{{base_url}}"],
              "path": ["api", "ipos", "statistics", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Statistics have required fields\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('total_ipos');",
                  "    pm.expect(jsonData).to.have.property('upcoming_ipos');",
                  "    pm.expect(jsonData).to.have.property('open_ipos');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create IPO (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"company_name\": \"API Test Company\",\n    \"sector\": 1,\n    \"ipo_open_date\": \"2024-03-01\",\n    \"ipo_close_date\": \"2024-03-03\",\n    \"price_band_min\": \"300.00\",\n    \"price_band_max\": \"320.00\",\n    \"lot_size\": 50,\n    \"total_issue_size\": 4000000000,\n    \"fresh_issue\": 2500000000,\n    \"offer_for_sale\": 1500000000,\n    \"rhp_link\": \"https://example.com/rhp/api-test.pdf\",\n    \"status\": \"upcoming\",\n    \"lead_managers\": \"Test Managers Ltd\",\n    \"registrar\": \"Test Registrar\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/ipos/",
              "host": ["{{base_url}}"],
              "path": ["api", "ipos", ""]
            }
          }
        },
        {
          "name": "Search IPOs by Name",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/ipos/?search=TechNova",
              "host": ["{{base_url}}"],
              "path": ["api", "ipos", ""],
              "query": [
                {
                  "key": "search",
                  "value": "TechNova"
                }
              ]
            }
          }
        },
        {
          "name": "Filter IPOs by Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/ipos/?status=upcoming",
              "host": ["{{base_url}}"],
              "path": ["api", "ipos", ""],
              "query": [
                {
                  "key": "status",
                  "value": "upcoming"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Sectors",
      "item": [
        {
          "name": "Get All Sectors",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/sectors/",
              "host": ["{{base_url}}"],
              "path": ["api", "sectors", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is array of sectors\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "    if (jsonData.length > 0) {",
                  "        pm.expect(jsonData[0]).to.have.property('name');",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Sector (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Test Sector\",\n    \"description\": \"Test sector created via API\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/sectors/",
              "host": ["{{base_url}}"],
              "path": ["api", "sectors", ""]
            }
          }
        }
      ]
    },
    {
      "name": "IPO Applications",
      "item": [
        {
          "name": "Get User Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications/",
              "host": ["{{base_url}}"],
              "path": ["api", "applications", ""]
            }
          }
        },
        {
          "name": "Apply for IPO",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"ipo\": 1,\n    \"bid_price\": \"260.00\",\n    \"quantity\": 2,\n    \"total_amount\": \"29120.00\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/applications/",
              "host": ["{{base_url}}"],
              "path": ["api", "applications", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Application created successfully\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('ipo');",
                  "    pm.expect(jsonData).to.have.property('bid_price');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "API Overview",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/",
              "host": ["{{base_url}}"],
              "path": ["api", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"API overview has endpoints\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('ipo_endpoints');",
                  "    pm.expect(jsonData).to.have.property('authentication');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ]
}